# ═══════════════════════════════════════════════
#  Murilo's Second Brain — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
#  NUNCA commitar o .env com valores reais!
# ═══════════════════════════════════════════════

# Domínio principal
DOMAIN=weissmurillo.de

# Brain API Key — usada pelo Claude para autenticar na Brain API
# Gere uma chave forte: openssl rand -hex 32
BRAIN_API_KEY=SUBSTITUA_POR_CHAVE_FORTE_MINIMO_32_CHARS

# JWT Secret do AppFlowy — DIFERENTE da BRAIN_API_KEY
# Gere uma chave forte: openssl rand -hex 32
APPFLOWY_JWT_SECRET=SUBSTITUA_POR_OUTRO_SECRET_FORTE_MINIMO_32_CHARS

# Email para certificado SSL (Let's Encrypt)
CERTBOT_EMAIL=seu@email.com
